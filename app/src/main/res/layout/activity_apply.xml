<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Apply for Job"
        android:textSize="20sp"
        android:textStyle="bold"
        android:padding="16dp"
        android:background="@color/black"
        android:textColor="@android:color/white"
        android:gravity="center" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter Your Details"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Name" />
            <EditText
                android:id="@+id/editTextName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. John Doe"
                android:inputType="textPersonName"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Highest Qualification" />
            <EditText
                android:id="@+id/editTextQualification"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. B.Tech in CS"
                android:inputType="text"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/buttonUploadResume"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Resume (PDF)"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/textViewFileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No file selected"
                android:textColor="@android:color/darker_gray"
                android:layout_marginBottom="32dp" />

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/buttonSubmitApplication"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Submit Application"
        android:layout_margin="16dp" />

</LinearLayout>
